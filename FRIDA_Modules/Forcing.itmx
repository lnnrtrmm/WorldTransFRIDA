			<module name="Land Use Forcing" isee:label="">
				<format scale_by="auto"/>
				<connect to="Forcing.Total_Land_use_forcing" from="Land_Use_Forcing.Total_Land_use_forcing"/>
				<connect2 to="Total_Land_use_forcing" from="Land_Use_Forcing.Total_Land_use_forcing"/>
				<connect to="Land_Use_Forcing.agricultural_water_withdrawal" from="Freshwater.agricultural_water_withdrawal"/>
				<connect2 to="Land_Use_Forcing.agricultural_water_withdrawal" from="Freshwater.agricultural_water_withdrawal"/>
				<connect to="Land_Use_Forcing.Albedo" from="Land_Use_and_Agriculture.Albedo"/>
				<connect2 to="Land_Use_Forcing.Albedo" from="Land_Use_and_Agriculture.Albedo"/>
