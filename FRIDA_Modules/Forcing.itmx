			<module name="N2O Forcing" isee:label="">
				<format scale_by="auto"/>
				<connect to="CH4_Forcing.Atmospheric_N2O_Concentration_1750" from="N2O_Forcing.Atmospheric_N2O_Concentration_1750"/>
