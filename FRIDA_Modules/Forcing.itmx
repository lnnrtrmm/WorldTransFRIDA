			<aux name="CO2 Effective Radiative Forcing" access="output">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(CO2_forcing_logarithmic_parameter*LN(Atmospheric_CO2_Concentration/Atmospheric_CO2_Concentration_1750[selected_climate_case_1[Run]]) + (SQRT(CO2_forcing_square_root_parameter_squared*Atmospheric_CO2_Concentration) - (SQRT(CO2_forcing_square_root_parameter_squared*Atmospheric_CO2_Concentration_1750[selected_climate_case_1[Run]])))) * (1+CO2_forcing_adjustment_due_to_fast_tropospheric_feedbacks)*Calibration_scaling_of_CO2_forcing[selected_climate_case_1[Run]]</eqn>
				<units>W/(metre^2)</units>
			</aux>
