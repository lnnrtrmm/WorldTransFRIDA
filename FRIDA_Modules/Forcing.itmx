	</model>
	<model name="N2O_Forcing">
		<variables>
			<aux name="Baseline N2O Lifetime">
				<eqn>109</eqn>
				<units>years</units>
			</aux>
			<aux name="Molecular Weight of N2O">
				<eqn>44.013</eqn>
				<units>g/mol</units>
			</aux>
			<aux name="N2O forcing adjustment due to\nfast tropospheric feedbacks">
				<eqn>0.07</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="N2O forcing\nsquare root parameter">
				<doc>f3 N2O</doc>
				<eqn>0.106</eqn>
				<units>(W/metre^2)/sqrt_ppb</units>
			</aux>
			<aux name="Atmospheric N2O\nConcentration 1750" access="output" isee:autocreated="true">
				<eqn>270.1</eqn>
				<units>ppb</units>
			</aux>
			<aux name="Scale factor for N2O lifetime">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>N2O_lifetime_parameter_2*EXP(N2O_lifetime_parameter_1/N2O_lifetime_parameter_3)</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="N2O lifetime parameter 2">
				<doc>g0 N2O</doc>
				<eqn>0.076755588</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="N2O lifetime parameter 3">
				<doc>g1 N2O</doc>
				<eqn>25.49528818</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="Baseline N2O lifetime parameter">
				<doc>iirf0 N2O</doc>
				<eqn>65.44969575</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="Effect of atmospheric N2O on N2O\nlifetime parameter">
				<doc>iirf airborne N2O</doc>
				<eqn>-0.0065</eqn>
				<units>1/MtN2O</units>
			</aux>
			<aux name="Effect of temperature on N2O\nlifetime parameter">
				<doc>iirf temperature N2O</doc>
				<eqn>0</eqn>
				<units>1/K</units>
			</aux>
			<aux name="Effect of N2O uptake on N2O\nlifetime parameter">
				<doc>iirf uptake N2O</doc>
				<eqn>0</eqn>
				<units>1/MtN2O</units>
			</aux>
			<aux name="N2O lifetime parameter 1">
				<doc>iirf N2O</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Baseline_N2O_lifetime_parameter + Effect_of_N2O_uptake_on_N2O_lifetime_parameter*(Cumulative_N2O_emissions*UNIT_ktN2O_to_MtN2O - N2O_in_atmosphere*UNIT_ktN2O_to_MtN2O) + Effect_of_temperature_on_N2O_lifetime_parameter*Surface_Temperature + Effect_of_atmospheric_N2O_on_N2O_lifetime_parameter*N2O_in_atmosphere*UNIT_ktN2O_to_MtN2O</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="Atmospheric N2O Concentration" access="output">
				<doc>${Calibrated Output,Explanatory Variable}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(N2O_in_atmosphere*UNIT_ktN2O_to_GtN2O/((Mass_of_the_Atmosphere_1/(UNIT_GtN2O_to_kg*UNIT_fraction_to_ppm))*Molecular_Weight_of_N2O/Molecular_Weight_of_Air_1))*UNIT_ppm_to_ppb_1  + Atmospheric_N2O_Concentration_1750</eqn>
				<units>ppb</units>
			</aux>
			<aux name="N2O Effective\nRadiative Forcing" access="output">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>((SQRT(N2O_forcing_square_root_parameter_squared*Atmospheric_N2O_Concentration) - (SQRT(N2O_forcing_square_root_parameter_squared*Atmospheric_N2O_Concentration_1750))) * (1+N2O_forcing_adjustment_due_to_fast_tropospheric_feedbacks))*Calibration_scaling_of_N2O_forcing[selected_climate_case[Run]]</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="UNIT ktN2O to GtN2O">
				<doc>${Unit}
</doc>
				<eqn>0.000001</eqn>
				<units>GtN2O/KtN2O</units>
			</aux>
			<aux name="UNIT GtN2O to kg">
				<doc>${Unit}
</doc>
				<eqn>1000000000000</eqn>
				<units>Kg/GtN2O</units>
			</aux>
			<aux name="N2O forcing\nsquare root parameter squared">
				<doc>f3 N2O squared</doc>
				<eqn>0.011236</eqn>
				<units>((W/metre^2)^2)/ppb</units>
			</aux>
			<aux name="Calibration scaling\nof N2O forcing">
				<doc>${External Parameter}
</doc>
				<dimensions>
					<dim name="ClimateCase"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.027167367</eqn>
				</element>
				<element subscript="2">
					<eqn>0.947683687</eqn>
				</element>
				<element subscript="3">
					<eqn>0.856794792</eqn>
				</element>
				<element subscript="4">
					<eqn>0.945188956</eqn>
				</element>
				<element subscript="5">
					<eqn>0.980251495</eqn>
				</element>
				<element subscript="6">
					<eqn>0.975361442</eqn>
				</element>
				<element subscript="7">
					<eqn>1.087907355</eqn>
				</element>
				<element subscript="8">
					<eqn>0.816164586</eqn>
				</element>
				<element subscript="9">
					<eqn>1.078038814</eqn>
				</element>
				<element subscript="10">
					<eqn>0.941322965</eqn>
				</element>
				<element subscript="11">
					<eqn>1.235837388</eqn>
				</element>
				<element subscript="12">
					<eqn>0.856029283</eqn>
				</element>
				<element subscript="13">
					<eqn>1.04613863</eqn>
				</element>
				<element subscript="14">
					<eqn>0.984626259</eqn>
				</element>
				<element subscript="15">
					<eqn>0.939024399</eqn>
				</element>
				<element subscript="16">
					<eqn>0.90115141</eqn>
				</element>
				<element subscript="17">
					<eqn>1.024014349</eqn>
				</element>
				<element subscript="18">
					<eqn>0.955841584</eqn>
				</element>
				<element subscript="19">
					<eqn>1.044179402</eqn>
				</element>
				<element subscript="20">
					<eqn>0.981036001</eqn>
				</element>
				<element subscript="21">
					<eqn>1.000080397</eqn>
				</element>
				<element subscript="22">
					<eqn>1.091695004</eqn>
				</element>
				<element subscript="23">
					<eqn>0.981360894</eqn>
				</element>
				<element subscript="24">
					<eqn>0.991719982</eqn>
				</element>
				<element subscript="25">
					<eqn>1.030424384</eqn>
				</element>
				<element subscript="26">
					<eqn>1.135827896</eqn>
				</element>
				<element subscript="27">
					<eqn>0.997046405</eqn>
				</element>
				<element subscript="28">
					<eqn>1.00542483</eqn>
