			<aux name="selected climate case 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>5</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Irrigation Forcing per\nIrrigation H2O Emissions">
				<eqn>-4.12e-14</eqn>
				<units>(W/(metre^2))/(((m)^3)/year)</units>
			</aux>
			<aux name="Fraction of Irrigation\nwater which is emitted">
				<eqn>0.432875474</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Irrigation Forcing">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Irrigation_Forcing_1980_relative_to_1750 + (Irrigation_Emissions - INIT(Irrigation_Emissions) )*Irrigation_Forcing_per_Irrigation_H2O_Emissions</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Irrigation Emissions">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>agricultural_water_withdrawal*Fraction_of_Irrigation_water_which_is_emitted</eqn>
				<units>m^3/year</units>
			</aux>
			<aux name="Total Land use forcing" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Irrigation_Forcing*Calibration_scaling_of_Irrigation_forcing[selected_climate_case_1[Run]] + Land_Use_Forcing_from_Albedo_Change*Calibration_scaling_of_Albedo_forcing[selected_climate_case_1[Run]]</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="agricultural water\nwithdrawal" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>m^3/year</units>
			</aux>
			<aux name="Land Use Forcing per\nchange in Land Use albedo">
				<eqn>-13.9646322</eqn>
				<units>(W/(metre^2))</units>
			</aux>
			<aux name="Land Use Forcing from\nAlbedo Change">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Land_Use_Forcing_1980_relative_to_1750 + (Albedo - INIT(Albedo))*Land_Use_Forcing_per_change_in_Land_Use_albedo</eqn>
				<units>(W/(metre^2))</units>
			</aux>
			<aux name="Albedo" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Land Use Forcing 1980\nrelative to 1750">
				<eqn>-0.13704706</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Irrigation Forcing 1980\nrelative to 1750">
				<eqn>-0.040305263</eqn>
				<units>W/(metre^2)</units>
			</aux>
