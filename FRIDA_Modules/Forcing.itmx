	<model name="CO2_Forcing">
		<variables>
			<aux name="Molecular Weight of CO2">
				<eqn>44.009</eqn>
				<units>g/mol</units>
			</aux>
			<aux name="Atmospheric CO2 Concentration" access="output">
				<doc>${Calibrated Output,Explanatory Variable}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Atmospheric_CO2_mass_anomaly_since_1750*UNIT_MtCO2_to_GtCO2/((Mass_of_the_Atmosphere/(UNIT_fraction_to_ppm*UNIT_GtCO2_to_kg))*(Molecular_Weight_of_CO2/Molecular_Weight_of_Air)) + Atmospheric_CO2_Concentration_1750[selected_climate_case_1[Run]]</eqn>
				<units>ppm</units>
			</aux>
			<aux name="Atmospheric CO2\nConcentration 1750">
				<doc>${External Parameter}
</doc>
				<dimensions>
					<dim name="ClimateCase"/>
				</dimensions>
				<element subscript="1">
					<eqn>276.8348651</eqn>
				</element>
				<element subscript="2">
					<eqn>276.5162939</eqn>
				</element>
				<element subscript="3">
					<eqn>279.6537782</eqn>
				</element>
				<element subscript="4">
					<eqn>277.5243358</eqn>
				</element>
				<element subscript="5">
					<eqn>279.8148292</eqn>
				</element>
				<element subscript="6">
					<eqn>276.9666748</eqn>
				</element>
				<element subscript="7">
					<eqn>276.03962</eqn>
				</element>
				<element subscript="8">
					<eqn>277.105962</eqn>
				</element>
				<element subscript="9">
					<eqn>276.7021397</eqn>
				</element>
				<element subscript="10">
					<eqn>279.0425899</eqn>
				</element>
				<element subscript="11">
					<eqn>278.1856781</eqn>
				</element>
				<element subscript="12">
					<eqn>279.994064</eqn>
