	<model name="CH4_Forcing">
		<variables>
			<aux name="Molecular Weight of CH4">
				<eqn>16.043</eqn>
				<units>g/mol</units>
			</aux>
			<aux name="Atmospheric CH4\nConcentration 1750" access="output" isee:autocreated="true">
				<eqn>729.2</eqn>
				<units>ppb</units>
			</aux>
			<aux name="CH4 forcing adjustment due to\nfast tropospheric feedbacks">
				<eqn>-0.14</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="CH4 forcing\nsquare root parameter">
				<doc>f3 CH4</doc>
				<eqn>0.038</eqn>
				<units>(W/metre^2)/sqrt_ppb</units>
			</aux>
			<aux name="Atmospheric CH4 Concentration" access="output">
				<doc>${Calibrated Output,Explanatory Variable}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(CH4_in_atmosphere*UNIT_MtCH4_to_GtCH4/((Mass_of_the_Atmosphere/(UNIT_GtCH4_to_kg*UNIT_fraction_to_ppm))*Molecular_Weight_of_CH4/Molecular_Weight_of_Air_1))*UNIT_ppm_to_ppb  + Atmospheric_CH4_Concentration_1750</eqn>
				<units>ppb</units>
			</aux>
			<aux name="CH4 Effective Radiative Forcing" access="output">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>((SQRT(CH4_forcing_square_root_parameter_squared*Atmospheric_CH4_Concentration) - (SQRT(CH4_forcing_square_root_parameter_squared*Atmospheric_CH4_Concentration_1750))) * (1+CH4_forcing_adjustment_due_to_fast_tropospheric_feedbacks))*Calibration_scaling_of_CH4_forcing[selected_climate_case_1[Run]]</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="UNIT GtCH4 to kg">
				<doc>${Unit}
</doc>
				<eqn>1000000000000</eqn>
				<units>Kg/GtCH4</units>
			</aux>
			<aux name="UNIT MtCH4 to GtCH4">
				<doc>${Unit}
</doc>
				<eqn>0.001</eqn>
				<units>GtCH4/MtCH4</units>
			</aux>
			<aux name="CH4 forcing\nsquare root parameter squared">
				<doc>f3 CH4 squared</doc>
				<eqn>0.001444</eqn>
				<units>((W/metre^2)^2)/ppb</units>
			</aux>
			<aux name="Calibration scaling\nof CH4 forcing">
				<doc>${External Parameter}
</doc>
				<dimensions>
					<dim name="ClimateCase"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.071470809</eqn>
				</element>
