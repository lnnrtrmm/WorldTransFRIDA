	</model>
	<model name="Coastal_Assets">
		<variables>
			<stock name="Unprotected\ncoastal assets">
				<eqn>Total_coastal_assets_in_1980 * (1 - Fraction_of_protected_coastal_assets_in_1980)</eqn>
				<inflow>Increase_of_unprotected_asset_values_through_GDP_growth</inflow>
				<inflow>Assets_changing_protection_status</inflow>
				<outflow>Annual_Damage_to_assets_due_to_flood_events</outflow>
				<outflow>Assets_being_retreated_from_the_coast</outflow>
				<units>b$</units>
			</stock>
			<aux name="Fraction of protected\ncoastal assets in 1980">
				<eqn>0.515</eqn>
				<units>dmnl</units>
			</aux>
			<flow name="Increase of unprotected\nasset values\nthrough GDP growth">
				<eqn>Unprotected_coastal_assets * Asset_growth_rate_in_unprotected_coastal_zones</eqn>
				<units>b$/year</units>
			</flow>
			<flow name="Annual\nDamage to\nassets due to\nflood events">
				<eqn>(1.0 - Flood_damage_resilience_in_unprotected_areas) * Unprotected_coastal_assets * Flood_depth_damage_function_for_capital_in_unprotected_areas</eqn>
				<units>b$/year</units>
			</flow>
			<flow name="Assets being retreated from the coast">
				<eqn>People_retreating_from_the_coast_1*Assets_per_person_in_unprotected_coastal_zones</eqn>
				<units>b$/year</units>
			</flow>
			<aux name="Flood depth damage function\nfor capital in\nunprotected areas">
				<eqn> Effective_flood_height_1*flood_damage_linear_param+Effective_flood_height_1^2*flood_damage_quadratic_param</eqn>
				<units>1/Year</units>
			</aux>
			<aux name="US GDP per capita in 2010">
				<doc>WATCH OUT: Need to check what kind of GDP per capita is needed. Is it in US$ 2010 value or with current values?

Current value is from:
https://data.worldbank.org/indicator/NY.GDP.PCAP.PP.KD?locations=US</doc>
				<eqn>54.51</eqn>
				<units>b$/Mp/year</units>
			</aux>
			<aux name="Flood damage resilience in unprotected areas">
				<eqn>Per_capita_GDP_in_unprotected_coastal_zones / (Per_capita_GDP_in_unprotected_coastal_zones + US_GDP_per_capita_in_2010)</eqn>
				<units>1</units>
			</aux>
			<aux name="Per capita GDP in\nunprotected coastal zones">
				<eqn>GDP_per_person[1]*
(1 - Fraction_of_protected_coastal_assets) /
(1 - Fraction_of_protected_people_in_coastal_zones)</eqn>
				<units>b$/Mp/year</units>
			</aux>
			<stock name="Protected\ncoastal assets">
				<eqn>Total_coastal_assets_in_1980 * Fraction_of_protected_coastal_assets_in_1980</eqn>
				<inflow>Increase_of_protected_asset_values_through_GDP_growth</inflow>
				<outflow>Loss_of_assets_through_increasing_flood_protection_height</outflow>
				<outflow>Assets_changing_protection_status</outflow>
				<units>b$</units>
			</stock>
			<flow name="Loss of assets through increasing\nflood protection height">
				<eqn>Annual_loss_of_capital_for_flood_protection</eqn>
				<units>b$/year</units>
			</flow>
			<flow name="Increase of protected\nasset values\nthrough GDP growth">
				<eqn>Protected_coastal_assets*GDP_growth_rate_1[1]</eqn>
				<units>b$/year</units>
			</flow>
			<aux name="Fraction of protected coastal assets">
				<eqn>Protected_coastal_assets / (Unprotected_coastal_assets + Protected_coastal_assets)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="flood damage linear param">
				<eqn>0.02</eqn>
				<units>1/metre/year</units>
			</aux>
			<aux name="flood damage quadratic param">
				<eqn>0.07</eqn>
				<units>1/metre^2/year</units>
			</aux>
			<aux name="Total coastal assets in 1980">
				<eqn>Fraction_of_global_assets_located_in_the_coastal_zone * INIT(Bank_Assets[1])</eqn>
				<units>b$</units>
			</aux>
			<aux name="Asset protection loss sensitvity">
				<eqn>0.864</eqn>
				<units>1/metre</units>
			</aux>
			<aux name="Asset protection gain sensitivity">
				<eqn>1.211</eqn>
				<units>1/metre</units>
			</aux>
			<flow name="Assets changing protection status">
				<eqn>IF change_in_protection_level &gt; 0 THEN
- MIN(Asset_protection_gain_sensitivity * change_in_protection_level* UNIT_year * Unprotected_coastal_assets,  Unprotected_coastal_assets) / UNIT_year
ELSE
MIN(Asset_protection_loss_sensitvity * ABS(change_in_protection_level)* UNIT_year * Protected_coastal_assets,  Protected_coastal_assets) / UNIT_year</eqn>
				<units>b$/year</units>
			</flow>
			<aux name="Assets per person in\nunprotected coastal zones">
				<eqn>Unprotected_coastal_assets/Unprotected_coastal_population_1</eqn>
				<units>b$/Mp</units>
			</aux>
			<aux name="Immobile\nassets lost\nduring\nretreat">
				<eqn>Assets_being_retreated_from_the_coast*Immobile_assets_fraction</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Immobile assets fraction">
				<doc>As in CIAM: 75% of capital are immobile and are lost during retreat</doc>
				<eqn>0.75</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Likelihood that people still\ninvest in unprotected\ncoastal zones">
				<eqn>1 - Expected_global_SLR_in_50_years_1 / (Expected_global_SLR_in_50_years_1+Expected_SLR_at_which_only_half_the_investment_would_be_made)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Expected SLR at which only half the investment would be made">
				<eqn>2.0</eqn>
				<units>metre</units>
			</aux>
			<aux name="Asset growth rate in unprotected coastal zones">
				<eqn>GDP_growth_rate_1[1] *Likelihood_that_people_still_invest_in_unprotected_coastal_zones</eqn>
				<units>1/year</units>
			</aux>
			<aux name="UNIT year" access="output" isee:autocreated="true">
				<eqn>1</eqn>
				<units>year</units>
			</aux>
			<aux name="GDP per person" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/Mp/year</units>
			</aux>
			<aux name="GDP\ngrowth rate 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<aux name="Expected global SLR\nin 50 years 1" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>metre</units>
			</aux>
			<aux name="Effective flood height 1" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>metre</units>
			</aux>
			<aux name="change in\nprotection level" access="output" throughput="true" isee:autocreated="true">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>metre/year</units>
			</aux>
			<aux name="Fraction of protected\npeople in coastal zones" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl</units>
			</aux>
			<stock name="Unprotected coastal\npopulation 1" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp</units>
			</stock>
			<aux name="People retreating from the coast 1" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="Annual loss of\ncapital for flood protection" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Total coastal assets">
				<eqn>Protected_coastal_assets + Unprotected_coastal_assets</eqn>
				<isee:summing/>
				<units>b$</units>
			</aux>
			<aux name="Bank\nAssets" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</aux>
			<aux name="Fraction of global assets located in the coastal zone">
				<eqn>0.1</eqn>
				<units>dmnl</units>
			</aux>
		</variables>
