	<macro name="PCTILE5">
		<eqn>out</eqn>
		<parm>in</parm>
		<variables>
			<aux name="in" access="input">
				<eqn>1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="out" access="output">
				<eqn>IF in = 1 THEN 0
ELSE IF in = 2 THEN 25
ELSE IF in = 3 THEN 50
ELSE IF in = 4 THEN 75
ELSE IF in = 5 THEN 100
ELSE 0</eqn>
				<units>dmnl</units>
			</aux>
		</variables>
