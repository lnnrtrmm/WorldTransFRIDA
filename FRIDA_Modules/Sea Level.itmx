				<connect2 to="Coastal_population.Retreat_switch" from="Retreat_switch"/>
			</module>
			<module name="Sea level rise\nadaptation" isee:label="">
				<format scale_by="auto"/>
				<connect to="Coastal_Assets.Annual_loss_of_capital_for_flood_protection" from="Sea_level_rise_adaptation.Annual_loss_of_capital_for_flood_protection"/>
				<connect2 to="Coastal_Assets.Annual_loss_of_capital_for_flood_protection" from="Sea_level_rise_adaptation.Annual_loss_of_capital_for_flood_protection"/>
				<connect to="Sea_Level.Increase_of_average_flood_protection_height_through_investment" from="Sea_level_rise_adaptation.Increase_of_average_flood_protection_height_through_investment"/>
				<connect2 to="Increase_of_average_flood_protection_height_through_investment" from="Sea_level_rise_adaptation.Increase_of_average_flood_protection_height_through_investment"/>
				<connect to="Sea_level_rise_adaptation.Effective_flood_height" from="Sea_Level.Effective_flood_height"/>
				<connect2 to="Sea_level_rise_adaptation.Effective_flood_height" from="Effective_flood_height"/>
				<connect to="Sea_level_rise_adaptation.Expected_global_SLR_in_50_years" from="Sea_Level.Expected_global_SLR_in_50_years"/>
				<connect2 to="Sea_level_rise_adaptation.Expected_global_SLR_in_50_years" from="Expected_global_SLR_in_50_years"/>
				<connect to="Sea_level_rise_adaptation.Willingness_to_invest_in_flood_protection_1" from="Sea_Level.Willingness_to_invest_in_flood_protection"/>
				<connect2 to="Sea_level_rise_adaptation.Willingness_to_invest_in_flood_protection_1" from="Willingness_to_invest_in_flood_protection"/>
			</module>
			<aux name="change in\nprotection level">
				<eqn>(Increase_of_average_flood_protection_height_through_investment - global_SLR_rate_of_increase[1])</eqn>
				<units>metre/year</units>
			</aux>
			<aux name="Increase of average\nflood protection height\nthrough investment" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>metre/year</units>
			</aux>
