<?xml version="1.0" encoding="utf-8"?>
<xmile version="1.0" xmlns="http://docs.oasis-open.org/xmile/ns/XMILE/v1.0" xmlns:isee="http://iseesystems.com/XMILE">
	<header>
		<smile version="1.0" namespace="std, isee" uses_arrays="1" uses_submodels=""/>
		<name>Sea Level</name>
		<uuid>643eb335-6f33-4fad-86db-c00593fce9f9</uuid>
		<vendor>isee systems, inc.</vendor>
		<product version="3.6" isee:build_number="3247" isee:saved_by_v1="true" lang="en">Stella Architect</product>
	</header>
	<sim_specs isee:sim_duration="0" isee:run_prefix="Run" isee:simulation_delay="0" isee:restore_on_start="false" isee:save_interval="1" method="RK4" time_units="Year" isee:instantaneous_flows="false" isee:ignore_module_errors="false" isee:strict_units="false" isee:loop_scores="false" isee:loop_exhaustive_allowed="1000">
		<start>1980</start>
		<stop>2100</stop>
		<dt reciprocal="true">8</dt>
	</sim_specs>
	<dimensions>
		<dim name="ClimateCase" size="11"/>
		<dim name="PCTILE">
			<elem name="Low"/>
			<elem name="P25"/>
			<elem name="Median"/>
			<elem name="P75"/>
			<elem name="High"/>
		</dim>
		<dim name="Run" size="1"/>
	</dimensions>
	<isee:prefs saved_runs="50" keep="false" show_module_prefix="true" live_update_on_drag="true" show_restore_buttons="false" layer="model" isee:design="Deluxe Prev-Next Blue Green Pastel" isee:design_custom="false" interface_scale_ui="true" interface_max_page_width="10000" interface_max_page_height="10000" interface_min_page_width="0" interface_min_page_height="0" rerun_on_structure_change="false" rifp="true">
		<isee:ignored_words>
			<isee:ignored_word>WolrdTrans</isee:ignored_word>
			<isee:ignored_word>WorldTrans</isee:ignored_word>
			<isee:ignored_word>IAM</isee:ignored_word>
			<isee:ignored_word>FRIDA</isee:ignored_word>
			<isee:ignored_word>IAMs</isee:ignored_word>
			<isee:ignored_word>Sectorized</isee:ignored_word>
			<isee:ignored_word>INvestment</isee:ignored_word>
			<isee:ignored_word>Edenhofer</isee:ignored_word>
			<isee:ignored_word>hydropower</isee:ignored_word>
		</isee:ignored_words>
	</isee:prefs>
	<isee:multiplayer_settings include_chat="true" allow_observers="false" advance_time_increment="1" max_advance_time_in_ms="0" model_stops_when_players_drop="false" observer_start_page="home_page" enabled="false"/>
	<isee:time_formats default_format="Builtin">
		<isee:time_format name="Builtin" type="adaptive"/>
	</isee:time_formats>
	<isee:number_format_extenders/>
	<default_format scale_by="1"/>
	<model_units>
		<unit name="Kilograms">
			<eqn/>
			<alias>kg</alias>
			<alias>kilogram</alias>
		</unit>
		<unit name="Years">
			<eqn/>
			<alias>yr</alias>
			<alias>year</alias>
		</unit>
		<unit name="Joules">
			<eqn/>
			<alias>j</alias>
			<alias>joule</alias>
		</unit>
		<unit name="Watts">
			<eqn/>
			<alias>w</alias>
			<alias>watt</alias>
		</unit>
		<unit name="Seconds">
			<eqn/>
			<alias>s</alias>
			<alias>second</alias>
		</unit>
		<unit name="G$">
			<eqn>Giga*$</eqn>
		</unit>
		<unit name="Gh">
			<eqn>Giga*h</eqn>
		</unit>
		<unit name="Gph">
			<eqn>Gh*p</eqn>
		</unit>
		<unit name="GtCO2e">
			<eqn>Giga*tCO2e</eqn>
		</unit>
		<unit name="k$">
			<eqn>kilo*$</eqn>
		</unit>
		<unit name="kh">
			<eqn>kilo*h</eqn>
		</unit>
		<unit name="M$">
			<eqn>Million*$</eqn>
		</unit>
		<unit name="Mha">
			<eqn>Million*ha</eqn>
		</unit>
		<unit name="Mkh">
			<eqn>Million*kh</eqn>
		</unit>
		<unit name="Mkm2">
			<eqn>Million*km2</eqn>
		</unit>
		<unit name="Mm2">
			<eqn>Million*m2</eqn>
		</unit>
		<unit name="Mp">
			<eqn>Million*p</eqn>
		</unit>
		<unit name="Mt redmeat">
			<eqn>Million*t redmeat</eqn>
		</unit>
		<unit name="MtCO2">
			<eqn>Million*tCO2</eqn>
		</unit>
		<unit name="Mtcrop">
			<eqn>Million*tcrop</eqn>
		</unit>
		<unit name="MtH2">
			<eqn>Million*tH2</eqn>
		</unit>
		<unit name="MtN">
			<eqn>Million*tN</eqn>
		</unit>
		<unit name="MtN2O">
			<eqn>Million*tN2O</eqn>
		</unit>
		<unit name="MZJ">
			<eqn>Million*ZJ</eqn>
		</unit>
		<unit name="MtCH4">
			<eqn>Million*tCH4</eqn>
		</unit>
		<unit name="MkgH2">
			<eqn>Million*kgH2</eqn>
		</unit>
		<unit name="TWh">
			<eqn>Million*MWh</eqn>
		</unit>
		<unit name="kWh">
			<eqn>kilo*w*h</eqn>
		</unit>
		<unit name="Mtoe">
			<eqn>Million*toe</eqn>
		</unit>
		<unit name="GW">
			<eqn>TWh/(kilo*h)</eqn>
		</unit>
		<unit name="kilowatt hours per day">
			<eqn>kWh/day</eqn>
		</unit>
		<unit name="kilowatts">
			<eqn>kW</eqn>
			<alias>kilowatt</alias>
		</unit>
		<unit name="Dollar">
			<eqn>$</eqn>
			<alias>Dollars</alias>
			<alias>$s</alias>
		</unit>
		<unit name="Hour">
			<eqn/>
			<alias>Hours</alias>
		</unit>
		<unit name="Person">
			<eqn/>
			<alias>People</alias>
			<alias>Persons</alias>
		</unit>
		<unit name="Unit">
			<eqn/>
			<alias>Units</alias>
		</unit>
		<unit name="Week">
			<eqn/>
			<alias>Weeks</alias>
		</unit>
		<unit name="MtSO2">
			<eqn>Million*tSO2</eqn>
		</unit>
		<unit name="M">
			<eqn>Million</eqn>
		</unit>
		<unit name="KtN2O">
			<eqn>kilo*tN2O</eqn>
		</unit>
		<unit name="MKg">
			<eqn>Million*kg</eqn>
		</unit>
		<unit name="p">
			<eqn>people</eqn>
		</unit>
		<unit name="item">
			<eqn/>
			<alias>items</alias>
		</unit>
		<unit name="order">
			<eqn/>
			<alias>orders</alias>
		</unit>
		<unit name="Dimensionless">
			<eqn>1</eqn>
			<alias>dmnl</alias>
			<alias>unitless</alias>
		</unit>
		<unit name="Kelvin">
			<eqn/>
			<alias>K</alias>
		</unit>
		<unit name="Day">
			<eqn/>
			<alias>Days</alias>
		</unit>
		<unit name="Month">
			<eqn/>
			<alias>Months</alias>
		</unit>
		<unit name="Euros">
			<eqn/>
			<alias>EUR</alias>
			<alias>euro</alias>
		</unit>
		<unit name="euros per year per person">
			<eqn>EUR/(person-year)</eqn>
		</unit>
		<unit name="G">
			<eqn>Giga</eqn>
		</unit>
		<unit name="GtCO2">
			<eqn>Giga*tCO2</eqn>
		</unit>
		<unit name="GtCH4">
			<eqn>Giga*tCH4</eqn>
		</unit>
		<unit name="GtN2O">
			<eqn>Giga*tN2O</eqn>
		</unit>
	</model_units>
	<model name="Sea_Level">
		<variables>
			<aux name="global SLR">
				<doc>${Calibrated,Output}
Total global sea-level rise with reference to 1993.

For a python version of the code and all references see: https://github.com/lnnrtrmm/sea-level-rise
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SLR_thermosteric+SLR_from_Greenland_Ice_Sheet+SLR_from_Antarctic_Ice_Sheet+SLR_from_mountain_glaciers+SLR_from_LWS</eqn>
				<units>metre</units>
			</aux>
			<stock name="SLR from GrIS SMB">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>yearly_SLR_from_GrIS_SMB</inflow>
				<units>metre</units>
			</stock>
			<flow name="yearly SLR from\nGrIS SMB">
				<doc>Li et al. (2020): &quot;Optimal temperature overshoot profile found by limiting global sea level rise as a lower-cost climate target&quot;, Science Advances, 6, eaaw9490

Fettweis et al. (2013): &quot;Estimating the Greenland ice sheet surface mass balance contribution to future sea level rise using the regional atmospheric climate model MAR&quot;, The Cryosphere, 7, 469–489</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF T_anomaly_for_SLR &lt;= 0 THEN 0
ELSE 
nu_GrIS_SMB *dmnl_to_Kelvin * (xi_GrIS_SMB*(Kelvin_to_dmnl*T_anomaly_for_SLR) + (1 - xi_GrIS_SMB) * (Kelvin_to_dmnl * T_anomaly_for_SLR)^phi_GrIS_SMB) * SQRT(1.0 - SLR_from_GrIS_SMB/maximum_GrIS_volume)</eqn>
				<non_negative/>
				<units>metre/Year</units>
			</flow>
			<aux name="SLR from\nAntarctic Ice Sheet">
				<doc>${Calibrated,Output}
Based on the BRICKv0.3 implementation (Wong et al., 2017), using the DAIS model (Shaffer, 2014).

Shaffer, G.: Formulation, calibration and validation of the DAIS model (version 1), a simple Antarctic ice sheet model sensitive to variations of sea level and ocean subsurface temperature, Geosci.Model Dev., 7, 1803–1818, https://doi.org/10.5194/gmd-7-1803-2014, 2014.

Wong, T. E., Bakker, A. M. R., Ruckert, K., Applegate, P., Slangen, A. B. A., and Keller, K.: BRICK v0.2, a simple, accessible, and transparent model framework for climate and regional sea-level projections, Geosci. Model Dev., 10, 2741–2760, https://doi.org/10.5194/gmd-10-2741-2017, 2017</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AntIS_max_contribution_to_SLR * (1.0 - AntIS_Volume/AntIS_initial_volume) + inital_SLR_from_AntIS</eqn>
				<units>metre</units>
			</aux>
			<stock name="SLR from\nmountain glaciers">
				<doc>${Calibrated,Output}
The uncertainty of the temperature input will lead to uncertainties in this component that already cover the given IPCC uncertainty range for this SLR component. Hence none of the input parameters is a calibration parameter.


Li et al. (2020): &quot;Optimal temperature overshoot profile found by limiting global sea level rise as a lower-cost climate target&quot;, Science Advances, 6, eaaw9490

Perrette et al. (2013): &quot;A scaling approach to project regional sea level rise and its uncertainties&quot;, Earth System Dynamics, 4, 11-29

Wigley and Raper (2005): &quot;Extended scenarios for glacier melt due to anthropogenic forcing&quot;, Geophys. Res. Lett. 32, L05704</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_SLR_from_MG</eqn>
				<inflow>yearly_MG_mass_loss</inflow>
				<units>metre</units>
			</stock>
			<flow name="yearly MG\nmass loss">
				<doc>The uncertainty of the temperature input will lead to uncertainties in this component that already cover the given IPCC uncertainty range for this SLR component. Hence none of the input parameters is a calibration parameter.


Li et al. (2020): &quot;Optimal temperature overshoot profile found by limiting global sea level rise as a lower-cost climate target&quot;, Science Advances, 6, eaaw9490

Perrette et al. (2013): &quot;A scaling approach to project regional sea level rise and its uncertainties&quot;, Earth System Dynamics, 4, 11-29

Wigley and Raper (2005): &quot;Extended scenarios for glacier melt due to anthropogenic forcing&quot;, Geophys. Res. Lett. 32, L05704</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt; 1850 THEN
MG_Tdep_rate * (dmnl_to_Kelvin *(Kelvin_to_dmnl * T_anomaly_for_SLR)^MG_temperature_nonlinearity) * (1 - SLR_from_mountain_glaciers/MG_max_sea_leve_rise)^MG_volume_nonlinearity
ELSE
0</eqn>
				<units>metre/Year</units>
			</flow>
			<aux name="T anomaly for SLR">
				<doc>Assuming that T anomaly between 1750 and 1850 is the same.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>UNIT_Celsius_to_Kelvin* Surface_Temperature_Anomaly</eqn>
				<units>K</units>
			</aux>
			<aux name="MG Tdep rate">
				<doc>${Assumption}
</doc>
				<eqn>0.0008</eqn>
				<units>metre/year/K</units>
			</aux>
			<aux name="MG max sea leve rise">
				<doc>${Assumption}
</doc>
				<eqn>0.41</eqn>
				<units>metre</units>
			</aux>
			<aux name="MG volume\nnonlinearity">
				<doc>${Assumption}
</doc>
				<eqn>1.646</eqn>
				<units>dmnl</units>
			</aux>
			<flow name="yearly thermosteric\nsea level change">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>energy_input_to_SLR_conversion_factor*yearly_ocean_energy_input</eqn>
				<units>metre/Year</units>
			</flow>
			<stock name="SLR thermosteric">
				<doc>${Calibrated,Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_thermosteric_SLR</eqn>
				<inflow>yearly_thermosteric_sea_level_change</inflow>
				<units>metre</units>
			</stock>
			<aux name="energy input to SLR conversion factor">
				<doc>${Calibration Parameter}
Kuhlbrodt, T., and Gregory, J. M. (2012), Ocean heat uptake and its consequences for the magnitude of sea level rise and climate change, Geophys. Res. Lett., 39, L18608, doi:10.1029/2012GL052952.

Meyssignac et al. (2019): Measuring Global Ocean Heat Content to Estimate the Earth Energy Imbalance. Front. Mar. Sci. 6:432. doi: 10.3389/fmars.2019.00432</doc>
				<eqn>0.105</eqn>
				<range min="0.09" max="0.12"/>
				<units>metre / YJ</units>
			</aux>
			<aux name="net downward\nradiative flux">
				<doc>This is equivalent to Eq. (7) in Cummings et al. (2020, https://doi.org/10.1175/JCLI-D-19-0589.1) and Eq. (10) in the FaIR2.0.0 model description paper (Leach et al., 2021, https://doi.org/10.5194/gmd-14-3007-2021)

N = -k1T1 + (1-epsilon)*k3*(T2-T3)</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>-(Heat_Capacity_of_Surface[selected_climate_case[Run]]*Change_in_Surface_Temperature +Heat_Capacity_of_Upper_Ocean[selected_climate_case[Run]]*Change_in_Upper_Ocean_Temperature
+Heat_Capacity_of_Deep_Ocean[selected_climate_case[Run]]*Change_in_Deep_Ocean_Temperature)</eqn>
				<units>W/metre^2</units>
			</aux>
			<aux name="seconds per year">
				<doc>${}
</doc>
				<eqn>31557600</eqn>
				<units>s/year</units>
			</aux>
			<aux name="yearly ocean\nenergy input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>net_downward_radiative_flux*earth_surface_area*seconds_per_year*Watt_to_Joule*Joule_to_YJ</eqn>
				<units>YJ/year</units>
			</aux>
			<aux name="earth surface area">
				<doc>${}
</doc>
				<eqn>510072000000000</eqn>
				<units>metre * metre</units>
			</aux>
			<aux name="Watt to Joule">
				<eqn>1</eqn>
				<units>J/W/s</units>
			</aux>
			<aux name="Joule to YJ">
				<eqn>1e-24</eqn>
				<units>YJ / J</units>
			</aux>
			<aux name="SLR from\nGreenland Ice Sheet">
				<doc>${Calibrated,Output}
Based on MAGICC6 model, reference:

Nauels et al. (2017): &quot;Synthesizing long-term sea level rise projections – the MAGICC sea level model v2.0&quot; in Geosci. Model Dev., 10, 2495–2524, https://doi.org/10.5194/gmd-10-2495-2017</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_SLR_from_GrIS+SLR_from_GrIS_SMB+SLR_from_GrIS_SID</eqn>
				<units>metre</units>
			</aux>
			<aux name="nu GrIS SMB">
				<doc>${}
</doc>
				<eqn>nu_GrIS_SMB_default * GrIS_parameter_scale_factor</eqn>
				<units>metre/K/Year</units>
			</aux>
			<aux name="phi GrIS SMB">
				<doc>${Assumption}
</doc>
				<eqn>2.0169</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="maximum GrIS volume">
				<doc>${Assumption}
</doc>
				<eqn>7.36</eqn>
				<units>metre</units>
			</aux>
			<aux name="xi GrIS SMB">
				<doc>${Assumption}
</doc>
				<eqn>0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Kelvin to dmnl">
				<eqn>1</eqn>
				<units>1/K</units>
			</aux>
			<aux name="dmnl to Kelvin">
				<eqn>1</eqn>
				<units>K</units>
			</aux>
			<aux name="SLR from GrIS SID">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>s_GrIS_SID*(GrIS_outlet_max-GrIS_SID_volume)</eqn>
				<units>metre</units>
			</aux>
			<aux name="s GrIS SID">
				<doc>${Assumption}
</doc>
				<eqn>5</eqn>
				<units>dmnl</units>
			</aux>
			<stock name="GrIS SID volume">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>GrIS_outlet_max</eqn>
				<outflow>yearly_reduction_of_outlet</outflow>
				<units>metre</units>
			</stock>
			<aux name="GrIS outlet max">
				<doc>${}
</doc>
				<eqn>GrIS_outlet_max_default * GrIS_parameter_scale_factor</eqn>
				<units>metre</units>
			</aux>
			<flow name="yearly reduction\nof outlet">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF T_anomaly_for_SLR &lt;= 0 THEN 0
ELSE
rho_GrIS_SID * GrIS_SID_volume * EXP(epsilon_GrIS_SID*T_anomaly_for_SLR)</eqn>
				<non_negative/>
				<units>metre/Year</units>
			</flow>
			<aux name="rho GrIS SID">
				<doc>${}
</doc>
				<eqn>rho_GrIS_SID_default * GrIS_parameter_scale_factor</eqn>
				<units>1/year</units>
			</aux>
			<aux name="epsilon GrIS SID">
				<doc>${Assumption}
</doc>
				<eqn>0.4722</eqn>
				<units>1/K</units>
			</aux>
			<aux name="density water">
				<eqn>1030</eqn>
				<units>kg / m^3</units>
			</aux>
			<aux name="density ice">
				<eqn>917</eqn>
				<units>kg / m^3</units>
			</aux>
			<aux name="density rock">
				<eqn>4000</eqn>
				<units>kg / m^3</units>
			</aux>
			<aux name="T freezing seawater">
				<doc>${Assumption}
</doc>
				<eqn>-1.8</eqn>
				<units>Celsius</units>
			</aux>
			<aux name="reference AntIS radius">
				<doc>${Assumption}
</doc>
				<eqn>1864000</eqn>
				<units>metre</units>
			</aux>
			<aux name="modern AntOcean\nsubsurface T">
				<doc>${Assumption}
</doc>
				<eqn>0.72</eqn>
				<units>Celsius</units>
			</aux>
			<aux name="AntIS epsilon1">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>density_ice/(density_rock-density_ice)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="AntIS epsilon2">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>density_water/(density_rock-density_ice)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="T to TAnt c1">
				<doc>${Assumption}
</doc>
				<eqn>14.279</eqn>
				<units>K</units>
			</aux>
			<aux name="T to TAnt c2">
				<doc>${Assumption}
</doc>
				<eqn>0.774</eqn>
				<units>K/Celsius</units>
			</aux>
			<aux name="Antarctic air temperature">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(T_anomaly_for_SLR-T_to_TAnt_c1)/T_to_TAnt_c2</eqn>
				<units>Celsius</units>
			</aux>
			<aux name="Antarctic subsurface\nocean temperature">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>T_freezing_seawater+(AntOcean_T_conversion_param_a*T_anomaly_for_SLR+AntOcean_T_conversion_param_b-T_freezing_seawater) 

/

(1.0 + EXP( -T_anomaly_for_SLR+(T_freezing_seawater-AntOcean_T_conversion_param_b) / AntOcean_T_conversion_param_a))</eqn>
				<units>Celsius</units>
			</aux>
			<aux name="AntOcean T\nconversion param a">
				<doc>${Assumption}
</doc>
				<eqn>0.2 + AntOcean_T_calibration*AntOcean_calibration_conversion</eqn>
				<units>Celsius / K</units>
			</aux>
			<aux name="AntOcean T conversion param b">
				<doc>${Assumption}
</doc>
				<eqn>0.4 + AntOcean_T_calibration</eqn>
				<units>Celsius</units>
			</aux>
			<aux name="AntIS param h0">
				<doc>${Assumption}
</doc>
				<eqn>1700</eqn>
				<units>metre</units>
			</aux>
			<aux name="AntIS param mu">
				<doc>${Assumption}
</doc>
				<eqn>8.7</eqn>
				<units>metre</units>
			</aux>
			<aux name="AntIS param nu">
				<eqn>0.012</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="AntIS param P0">
				<doc>${Assumption}
P0 is the (ice equivalent) precipitation at 0 ◦C

Shaffer (2014)</doc>
				<eqn>0.35</eqn>
				<units>metre/year</units>
			</aux>
			<aux name="AntIS param gamma">
				<doc>${Assumption}
</doc>
				<eqn>2</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="AntIS param alpha">
				<doc>${Assumption}
</doc>
				<eqn>0.35</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="AntIS param kappa">
				<doc>${Assumption}
κ is chosen assuming a relationship
between columnar water content (that increases exponentially with temperature) and precipitation

Shaffer (2014)</doc>
				<eqn>0.04</eqn>
				<units>1/Celsius</units>
			</aux>
			<aux name="AntIS param f0">
				<doc>${Assumption}
</doc>
				<eqn>1.2</eqn>
				<units>metre/year</units>
			</aux>
			<aux name="AntIS param c">
				<doc>${Assumption}
</doc>
				<eqn>95</eqn>
				<units>metre/Celsius</units>
			</aux>
			<aux name="AntIS param b0">
				<doc>${Assumption}
</doc>
				<eqn>775</eqn>
				<units>metre</units>
			</aux>
			<aux name="AntIS param slope">
				<doc>${Assumption}
</doc>
				<eqn>0.0006</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="AntIS hr">
				<doc>hR(Ta) is the height of the runoff line above which
precipitation, P (Ta), is assumed to accumulate as snow and
β(P ) is a rate of mass balance increase with height. Sublimation has been disregarded here

Shaffer (2014)</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AntIS_param_h0+AntIS_param_c*Antarctic_air_temperature</eqn>
				<units>metre</units>
			</aux>
			<aux name="AntIS rc">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(AntIS_param_b0-global_SLR)/AntIS_param_slope</eqn>
				<units>metre</units>
			</aux>
			<aux name="AntIS P">
				<doc>P (Ta), is assumed to accumulate as snow</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AntIS_param_P0*EXP(AntIS_param_kappa*Antarctic_air_temperature)</eqn>
				<units>metre/year</units>
			</aux>
			<aux name="AntIS beta">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AntIS_param_nu*SQRT(UNIT_per_m*AntIS_P/UNIT_per_year) * UNIT_per_year</eqn>
				<units>1/year</units>
			</aux>
			<aux name="AntIS rR">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AntIS_Radius-((AntIS_hr-AntIS_param_b0+AntIS_param_slope*AntIS_Radius)^2)/AntIS_param_mu</eqn>
				<units>metre</units>
			</aux>
			<aux name="AntIS Btot">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF AntIS_hr &gt; 0 
THEN
AntIS_P*PI*AntIS_Radius^2 - PI * AntIS_beta * (AntIS_hr - AntIS_param_b0 + AntIS_param_slope  * AntIS_Radius) * (AntIS_Radius^2 - AntIS_rR^2) 
+ 4.0 * PI * AntIS_beta 
* SQRT(AntIS_param_mu*UNIT_per_m)/UNIT_per_m
*  (AntIS_Radius*( (UNIT_per_m*(AntIS_Radius-AntIS_rR))^1.5) / UNIT_per_m  / 3.0 - ((UNIT_per_m*(AntIS_Radius-AntIS_rR))^2.5/UNIT_per_m^2) / 5.0)

ELSE
AntIS_P*PI*AntIS_Radius^2</eqn>
				<units>metre^3/year</units>
			</aux>
			<aux name="AntIS fac">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF AntIS_Radius &gt; AntIS_rc THEN
AntIS_fac2
ELSE
AntIS_fac1</eqn>
				<units>metre*metre</units>
			</aux>
			<aux name="AntIS F">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF AntIS_Radius &gt; AntIS_rc THEN
2.0 * PI * AntIS_Radius * AntIS_delta * AntIS_Hw * AntIS_speed
ELSE
0.0</eqn>
				<units>metre^3/year</units>
			</aux>
			<aux name="AntIS ISO">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF AntIS_Radius &gt; AntIS_rc THEN
AntIS_cISO * global_SLR_rate_of_increase
ELSE
0.0</eqn>
				<units>metre^3/year</units>
			</aux>
			<aux name="AntIS fac1">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>PI * (1.0 + AntIS_epsilon1) * (4.0/3.0 * SQRT(AntIS_param_mu*UNIT_per_m)/UNIT_per_m * (AntIS_Radius * UNIT_per_m)^1.5/UNIT_per_m - AntIS_param_slope * AntIS_Radius^2)</eqn>
				<units>metre*metre</units>
			</aux>
			<aux name="AntIS fac2">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AntIS_fac1 - 2.0 * PI * AntIS_epsilon2 * (AntIS_param_slope*AntIS_Radius^2 - AntIS_param_b0*AntIS_Radius)</eqn>
				<units>metre*metre</units>
			</aux>
			<aux name="AntIS Hw">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AntIS_param_slope*AntIS_Radius-AntIS_param_b0+global_SLR</eqn>
				<units>metre</units>
			</aux>
			<aux name="AntIS speed">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AntIS_param_f0 * ((1.0 - AntIS_param_alpha) + AntIS_param_alpha * ((Antarctic_subsurface_ocean_temperature - T_freezing_seawater)/(modern_AntOcean_subsurface_T - T_freezing_seawater))^2) * ((AntIS_Hw*UNIT_per_m)^AntIS_param_gamma/UNIT_per_m) / ((UNIT_per_m*(AntIS_param_slope*reference_AntIS_radius - AntIS_param_b0))^(AntIS_param_gamma-1.0)/UNIT_per_m)</eqn>
				<units>metre/year</units>
			</aux>
			<aux name="AntIS delta">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>density_water/density_ice</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="AntIS cISO">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>2.0 * PI * AntIS_epsilon2 * (AntIS_param_slope*AntIS_rc^2 - (AntIS_param_b0/AntIS_param_slope)*AntIS_rc)</eqn>
				<units>metre*metre</units>
			</aux>
			<aux name="global SLR\nrate of increase">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>UNIT_per_year * (global_SLR - DELAY(global_SLR, 1))</eqn>
				<units>metre/year</units>
			</aux>
			<stock name="AntIS Volume">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AntIS_initial_volume</eqn>
				<inflow>yearly_change_in_AntIS_Volume</inflow>
				<units>metre^3</units>
			</stock>
			<stock name="AntIS Radius">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>reference_AntIS_radius</eqn>
				<inflow>yearly_change_in_AntIS_Radius</inflow>
				<units>metre</units>
			</stock>
			<flow name="yearly change in\nAntIS Radius">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(AntIS_Btot-AntIS_F+AntIS_ISO-AntIS_disintegration_volume_through_MICI)/AntIS_fac</eqn>
				<units>metre/Year</units>
			</flow>
			<flow name="yearly change in\nAntIS Volume">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AntIS_Btot-AntIS_F+AntIS_ISO-AntIS_disintegration_volume_through_MICI</eqn>
				<units>metre^3/Year</units>
			</flow>
			<aux name="UNIT per year">
				<eqn>1</eqn>
				<units>1/year</units>
			</aux>
			<aux name="AntIS initial volume">
				<doc>${Assumption}
</doc>
				<eqn>2.4791721932922064e+16</eqn>
				<units>metre^3</units>
			</aux>
			<aux name="AntIS max\ncontribution to SLR">
				<doc>${Assumption}
</doc>
				<eqn>57</eqn>
				<units>metre</units>
			</aux>
			<aux name="UNIT per m">
				<eqn>1</eqn>
				<units>1/metre</units>
			</aux>
			<aux name="Surface Temperature Anomaly" access="output" throughput="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>deg C</units>
			</aux>
			<aux name="UNIT Celsius\nto Kelvin">
				<eqn>1</eqn>
				<units>K/deg C</units>
			</aux>
			<aux name="SLR thermosteric by PCTILE">
				<doc>${Output}
</doc>
				<dimensions>
					<dim name="PCTILE"/>
				</dimensions>
				<eqn>PERCENTILE(SLR_thermosteric, PCTILE5(PCTILE), PCTILE5(PCTILE-1))</eqn>
				<units>metre</units>
			</aux>
			<aux name="SLR from\nmountain glaciers by PCTILE">
				<doc>${Output}
</doc>
				<dimensions>
					<dim name="PCTILE"/>
				</dimensions>
				<eqn>PERCENTILE(SLR_from_mountain_glaciers, PCTILE5(PCTILE), PCTILE5(PCTILE-1))</eqn>
				<units>metre</units>
			</aux>
			<aux name="selected climate case" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Population Mp" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp</units>
			</aux>
			<aux name="SLR from LWS">
				<doc>${Calibrated,Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Population_Mp*LWS_per_capita+LWS_with_no_people)/millimetre_to_metre</eqn>
				<units>metre</units>
			</aux>
			<aux name="LWS per capita">
				<eqn>0.00454881166977024</eqn>
				<units>millimetre/Mp</units>
			</aux>
			<aux name="LWS with no people">
				<eqn>-26.4661992747091</eqn>
				<units>millimetre</units>
			</aux>
			<aux name="millimetre to metre">
				<eqn>1000</eqn>
				<units>millimetre/metre</units>
			</aux>
			<aux name="initial SLR from GrIS">
				<eqn>-0.0028</eqn>
				<units>metre</units>
			</aux>
			<aux name="inital SLR from AntIS">
				<eqn>0.0</eqn>
				<units>metre</units>
			</aux>
			<aux name="initial SLR from MG">
				<eqn>-0.0035</eqn>
				<units>metre</units>
			</aux>
			<aux name="initial thermosteric SLR">
				<eqn>-0.008</eqn>
				<units>metre</units>
			</aux>
			<aux name="MG temperature\nnonlinearity">
				<doc>${Assumption}
</doc>
				<eqn>1.5</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="GrIS parameter scale factor">
				<doc>${Calibration Parameter}
This is a calibration parameter that leads to changes in rho, nu and GIS_outlet_max, because all these parameters can be  calibrated (see Nauels et al. (2017)</doc>
				<eqn>0.85</eqn>
				<range min="0.7" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="AntOcean T calibration">
				<doc>${Calibration Parameter}
</doc>
				<eqn>0.04</eqn>
				<range min="0.02" max="0.07"/>
				<units>Celsius</units>
			</aux>
			<aux name="AntOcean calibration\nconversion">
				<doc>${Assumption}
</doc>
				<eqn>3.0</eqn>
				<units>1/K</units>
			</aux>
			<aux name="Include MICI behaviour">
				<eqn>0</eqn>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="AntIS disintegration volume\nthrough MICI">
				<eqn>IF Antarctic_air_temperature[1] &gt; AntIS_MICI_critical_Tant THEN
Include_MICI_behaviour * AntIS_MICI_disintegration_rate * AntIS_initial_volume / AntIS_max_contribution_to_SLR ELSE 0</eqn>
				<units>metre^3/year</units>
			</aux>
			<aux name="AntIS MICI\ndisintegration rate">
				<doc>${Calibration Parameter}
</doc>
				<eqn>0.0093</eqn>
				<range min="0.0045" max="0.017"/>
				<units>metre/year</units>
			</aux>
			<aux name="AntIS MICI critical Tant">
				<doc>${Calibration Parameter}
</doc>
				<eqn>-15.0</eqn>
				<range min="-16" max="-14.6"/>
				<units>Celsius</units>
			</aux>
			<aux name="SLR from Greenland\nIce Sheet by PCTILE">
				<doc>${Output}
</doc>
				<dimensions>
					<dim name="PCTILE"/>
				</dimensions>
				<eqn>PERCENTILE(SLR_from_Greenland_Ice_Sheet, PCTILE5(PCTILE), PCTILE5(PCTILE-1))</eqn>
				<units>metre</units>
			</aux>
			<aux name="SLR from Antarctic\nIce Sheet by PCTILE">
				<doc>${Output}
</doc>
				<dimensions>
					<dim name="PCTILE"/>
				</dimensions>
				<eqn>PERCENTILE(SLR_from_Antarctic_Ice_Sheet, PCTILE5(PCTILE), PCTILE5(PCTILE-1))</eqn>
				<units>metre</units>
			</aux>
			<aux name="global SLR by PCTILE">
				<doc>${Output}
</doc>
				<dimensions>
					<dim name="PCTILE"/>
				</dimensions>
				<eqn>PERCENTILE(global_SLR, PCTILE5(PCTILE), PCTILE5(PCTILE-1))</eqn>
				<units>metre</units>
			</aux>
			<aux name="SLR from LWS by PCTILE">
				<doc>${Output}
</doc>
				<dimensions>
					<dim name="PCTILE"/>
				</dimensions>
				<eqn>PERCENTILE(SLR_from_LWS, PCTILE5(PCTILE), PCTILE5(PCTILE-1))</eqn>
				<units>metre</units>
			</aux>
			<aux name="GrIS outlet max default">
				<doc>${Assumption}
</doc>
				<eqn>0.05363</eqn>
				<units>metre</units>
			</aux>
			<aux name="rho GrIS SID default">
				<doc>${Assumption}
</doc>
				<eqn>0.0007933</eqn>
				<units>1/year</units>
			</aux>
			<aux name="nu GrIS SMB default">
				<doc>${Assumption}
</doc>
				<eqn>0.0001148</eqn>
				<units>metre/K/Year</units>
			</aux>
			<aux name="Change in Surface Temperature" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>K/Years</units>
			</aux>
			<aux name="Change in Deep Ocean Temperature" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>K/Years</units>
			</aux>
			<aux name="Change in Upper Ocean Temperature" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>K/Years</units>
			</aux>
			<aux name="Heat Capacity of Deep Ocean" access="input">
				<dimensions>
					<dim name="ClimateCase"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>W*year/metre^2/K</units>
			</aux>
			<aux name="Heat Capacity of Surface" access="input">
				<dimensions>
					<dim name="ClimateCase"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>W*year/metre^2/K</units>
			</aux>
			<aux name="Heat Capacity of Upper Ocean" access="input">
				<dimensions>
					<dim name="ClimateCase"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>W*year/metre^2/K</units>
			</aux>
			<aux name="Expected global SLR\nin 50 years">
				<eqn>global_SLR[1] + Surface_Temperature_Anomaly_1[1]*Sensitivity_of_expected_SLR_to_T_anomaly + Total_CO2_Emissions[1] * Sensitivity_of_expected_SLR_to_CO2_emissions</eqn>
				<units>metre</units>
			</aux>
			<aux name="Willingness to invest\nin flood protection">
				<doc>Between 0 and 1</doc>
				<eqn>0.0 {0, 1}</eqn>
				<units>1</units>
			</aux>
			<aux name="Sensitivity of expected\nSLR to CO2 emissions">
				<eqn>0.00000348</eqn>
				<units>metre / (MtCO2 / yr )</units>
			</aux>
			<aux name="Sensitivity of expected\nSLR to T anomaly">
				<eqn>0.086</eqn>
				<units>metre/(deg C)</units>
			</aux>
			<aux name="Surface Temperature Anomaly 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>deg C</units>
			</aux>
			<aux name="Total CO2 Emissions" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>MtCO2/Year</units>
			</aux>
			<aux name="Effective flood\nheight in 1980">
				<eqn>0.0</eqn>
				<units>metre</units>
			</aux>
			<aux name="Effective flood height">
				<doc>For simplicity it is assumed that the effective flood height is 0 in 1980, leading to no flood damages in that year. The effective flood height is then simply the global SLR.</doc>
				<eqn>Effective_flood_height_in_1980+global_SLR[1]</eqn>
				<units>metre</units>
			</aux>
			<aux name="Retreat switch">
				<eqn>0.0 {0, 1}</eqn>
				<units>1/year</units>
			</aux>
			<module name="Coastal Assets" isee:label="">
				<format scale_by="auto"/>
				<connect to="Coastal_Assets.Annual_loss_of_capital_for_flood_protection" from="Sea_level_rise_adaptation.Annual_loss_of_capital_for_flood_protection"/>
				<connect2 to="Coastal_Assets.Annual_loss_of_capital_for_flood_protection" from="Sea_level_rise_adaptation.Annual_loss_of_capital_for_flood_protection"/>
				<connect to="Coastal_Assets.Bank_Assets" from="Finance.Bank_Assets"/>
				<connect2 to="Coastal_Assets.Bank_Assets" from="Finance.Bank_Assets"/>
				<connect to="Coastal_Assets.change_in_protection_level" from="Sea_Level.change_in_protection_level"/>
				<connect2 to="Coastal_Assets.change_in_protection_level" from="change_in_protection_level"/>
				<connect to="Coastal_Assets.Effective_flood_height_1" from="Sea_Level.Effective_flood_height"/>
				<connect2 to="Coastal_Assets.Effective_flood_height_1" from="Effective_flood_height"/>
				<connect to="Coastal_Assets.Expected_global_SLR_in_50_years_1" from="Sea_Level.Expected_global_SLR_in_50_years"/>
				<connect2 to="Coastal_Assets.Expected_global_SLR_in_50_years_1" from="Expected_global_SLR_in_50_years"/>
				<connect to="Coastal_Assets.Fraction_of_protected_people_in_coastal_zones" from="Coastal_population.Fraction_of_protected_people_in_coastal_zones"/>
				<connect2 to="Coastal_Assets.Fraction_of_protected_people_in_coastal_zones" from="Coastal_population.Fraction_of_protected_people_in_coastal_zones"/>
				<connect to="Coastal_Assets.GDP_growth_rate_1" from="GDP.GDP_growth_rate"/>
				<connect2 to="Coastal_Assets.GDP_growth_rate_1" from="GDP.GDP_growth_rate"/>
				<connect to="Coastal_Assets.GDP_per_person" from="Population.GDP_per_person"/>
				<connect2 to="Coastal_Assets.GDP_per_person" from="Population.GDP_per_person"/>
				<connect to="Coastal_Assets.People_retreating_from_the_coast_1" from="Coastal_population.People_retreating_from_the_coast"/>
				<connect2 to="Coastal_Assets.People_retreating_from_the_coast_1" from="Coastal_population.People_retreating_from_the_coast"/>
				<connect to="Coastal_Assets.Unprotected_coastal_population_1" from="Coastal_population.Unprotected_coastal_population"/>
				<connect2 to="Coastal_Assets.Unprotected_coastal_population_1" from="Coastal_population.Unprotected_coastal_population"/>
			</module>
			<module name="Coastal\npopulation" isee:label="">
				<format scale_by="auto"/>
				<connect to="Coastal_Assets.Fraction_of_protected_people_in_coastal_zones" from="Coastal_population.Fraction_of_protected_people_in_coastal_zones"/>
				<connect2 to="Coastal_Assets.Fraction_of_protected_people_in_coastal_zones" from="Coastal_population.Fraction_of_protected_people_in_coastal_zones"/>
				<connect to="Coastal_Assets.People_retreating_from_the_coast_1" from="Coastal_population.People_retreating_from_the_coast"/>
