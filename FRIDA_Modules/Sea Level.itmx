	</model>
	<model name="Coastal_Assets">
		<variables>
			<stock name="Coastal assets" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>Coastal_assets_in_1980[Coastal_Protection_level]</eqn>
				<inflow>Increase_of_coastal_asset_values_through_GDP_growth</inflow>
				<outflow>Annual_Damage_to_assets_due_to_flood_events</outflow>
				<outflow>Assets_being_retreated_from_the_coast</outflow>
				<outflow>Loss_of_assets_through_increasing_flood_protection_height</outflow>
				<units>b$</units>
			</stock>
			<aux name="Fraction of protected\ncoastal assets in 1980">
				<doc>From the DIVA spreadsheet. Protected are all segments with a flood protection height higher than the s1000 flood.</doc>
				<eqn>0.7531</eqn>
				<units>dmnl</units>
			</aux>
			<flow name="Increase of coastal\nasset values\nthrough GDP growth">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<element subscript="1, well_protected">
					<eqn>Total_annual_growth_of_coastal_asset_values[Run]-Investment_in_badly_protected_coastal_assets[Run]</eqn>
				</element>
				<element subscript="1, insufficient">
					<eqn>Investment_in_badly_protected_coastal_assets[Run]</eqn>
				</element>
				<units>b$/year</units>
			</flow>
			<flow name="Annual\nDamage to\nassets due to\nflood events">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>(1.0 - Flood_damage_resilience) * Coastal_assets * Flood_damage_function_for_assets_in_coastal_areas</eqn>
				<units>b$/year</units>
			</flow>
			<flow name="Assets being retreated from the coast">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>People_retreating_from_the_coast_1*Coastal_assets_per_person</eqn>
				<units>b$/year</units>
			</flow>
			<aux name="Flood damage function\nfor assets in coastal areas">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>MIN(1, asset_flood_damage_sensitivity * Flood_height_for_damage^asset_flood_damage_elasticity)</eqn>
				<units>1/Year</units>
			</aux>
			<aux name="US GDP per capita in 2010" access="output" isee:autocreated="true">
				<doc>WATCH OUT: Need to check what kind of GDP per capita is needed. Is it in US$ 2010 value or with current values?

Current value is from:
https://data.worldbank.org/indicator/NY.GDP.PCAP.PP.KD?locations=US</doc>
				<eqn>54.51</eqn>
				<units>b$/Mp/year</units>
			</aux>
			<aux name="Flood damage\nresilience" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>GDP_per_capita_in_coastal_zones / (GDP_per_capita_in_coastal_zones + US_GDP_per_capita_in_2010)</eqn>
				<units>1</units>
			</aux>
			<aux name="Fraction of well protected\ncoastal assets">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Coastal_assets[Run,well_protected] / (Coastal_assets[Run,well_protected] + Coastal_assets[Run,insufficient])</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="asset flood damage sensitivity">
				<eqn>0.1</eqn>
				<units>1/year</units>
			</aux>
			<aux name="asset flood damage elasticity">
				<eqn>1.2</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Coastal assets in 1980">
				<dimensions>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<element subscript="well_protected">
					<eqn>Fraction_of_global_assets_located_in_the_coastal_zone * INIT(Bank_Assets[1]) * Fraction_of_protected_coastal_assets_in_1980</eqn>
				</element>
				<element subscript="insufficient">
					<eqn>Fraction_of_global_assets_located_in_the_coastal_zone * INIT(Bank_Assets[1]) * (1.0 - Fraction_of_protected_coastal_assets_in_1980)</eqn>
				</element>
				<units>b$</units>
			</aux>
			<aux name="Coastal assets per person">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>Coastal_assets/Unprotected_coastal_population_1</eqn>
				<units>b$/Mp</units>
			</aux>
			<aux name="Immobile assets\nlost during retreat">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>Assets_being_retreated_from_the_coast*Immobile_assets_fraction</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Immobile assets fraction">
				<doc>As in CIAM: 75% of capital are immobile and are lost during retreat</doc>
				<eqn>0.75</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Likelihood that people still\ninvest in badly protected\ncoastal zones">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1 - MAX(0,  (Expected_effective_flood_height_in_50_years[Run,insufficient]) / (Expected_effective_flood_height_in_50_years[Run,insufficient]+Effective_flood_height_at_which_only_half_the_investment_would_be_made))</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Effective flood height at which only half\nthe investment would be made">
				<eqn>1.0</eqn>
				<units>metre</units>
			</aux>
			<aux name="GDP\ngrowth rate 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<aux name="Effective flood height 1" access="input">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>metre</units>
			</aux>
			<stock name="Unprotected coastal\npopulation 1" access="input">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp</units>
			</stock>
			<aux name="People retreating from the coast 1" access="input">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="Annual loss of\ncapital for flood protection" access="input">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Bank\nAssets" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</aux>
			<aux name="Fraction of global assets located in the coastal zone">
				<eqn>0.1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Total annual growth of\ncoastal asset values">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Coastal_assets[Run,well_protected] + Coastal_assets[Run,insufficient])*GDP_growth_rate_1[1]</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Investment in badly protected\ncoastal assets">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Total_annual_growth_of_coastal_asset_values*(1.0 - Fraction_of_well_protected_coastal_assets) * Likelihood_that_people_still_invest_in_badly_protected_coastal_zones</eqn>
				<units>b$/year</units>
			</aux>
			<flow name="Loss of assets through increasing\nflood protection height">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>Annual_loss_of_capital_for_flood_protection</eqn>
				<units>b$/year</units>
			</flow>
			<aux name="GDP per capita\nin coastal zones" access="input">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/Mp/year</units>
			</aux>
			<aux name="Effective\nflood height" access="input">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>metre</units>
			</aux>
			<aux name="Expected global SLR\nin 50 years" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>metre</units>
			</aux>
			<aux name="Flood height for damage" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>MAX(0,  Effective_flood_height_1) / UNIT_metre</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="UNIT metre">
				<eqn>1</eqn>
				<units>metre</units>
			</aux>
			<aux name="Proportion of all assets\ndamaged due to SLR" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>time_over_which_assets_are_damaged*(Total_annual_asset_loss_in_flood_events+Total_annual_asset_loss_during_retreat+Total_annual_asset_loss_for_flood_protection)/Bank_Assets</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="time over which assets are damaged">
				<eqn>1</eqn>
				<units>year</units>
			</aux>
			<aux name="Total annual asset loss in flood events" isee:derived_units="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Annual_Damage_to_assets_due_to_flood_events[Run, well_protected] + Annual_Damage_to_assets_due_to_flood_events[Run, insufficient]</eqn>
				<isee:summing/>
				<units>b$/year</units>
			</aux>
			<aux name="Total annual asset loss\nduring retreat" isee:derived_units="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Immobile_assets_lost_during_retreat[Run, well_protected] + Immobile_assets_lost_during_retreat[Run, insufficient]</eqn>
				<isee:summing/>
				<units>b$/year</units>
			</aux>
			<aux name="Total annual asset loss\nfor flood protection" isee:derived_units="true" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Annual_loss_of_capital_for_flood_protection[Run, well_protected] + Annual_loss_of_capital_for_flood_protection[Run, insufficient]</eqn>
				<isee:summing/>
				<units>b$/year</units>
			</aux>
			<aux name="Expected effective flood height in 50 years">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>MAX(0,  Effective_flood_height + Expected_global_SLR_in_50_years[Run] - Potential_increase_of_flood_protection_height_over_next_50_years)</eqn>
				<units>metre</units>
			</aux>
			<aux name="Potential increase of flood\nprotection height\nover next 50 years" access="input">
				<dimensions>
					<dim name="Run"/>
					<dim name="Coastal_Protection_level"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>metre</units>
			</aux>
		</variables>
