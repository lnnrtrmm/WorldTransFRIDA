				<aux font_style="italic" font_weight="bold" label_side="top" x="1185" y="248.667" name="Effective flood height 1"/>
				<connector uid="46" angle="185.711">
					<from>Effective_flood_height_1</from>
					<to>Flood_depth_damage_function_for_capital_in_unprotected_areas</to>
				</connector>
				<aux font_style="italic" font_weight="bold" x="982.71" y="570.717" name="change in\nprotection level"/>
				<connector uid="50" angle="110.171">
