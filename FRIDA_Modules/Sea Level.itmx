				<aux color="blue" label_side="center" x="1081.49" y="293.553" width="78.5953" height="78.5953" name="Annual\ncosts of\nflood protection\nmaintenance"/>
				<aux color="blue" label_side="left" label_angle="225" x="358.16" y="478.72" width="36.125" height="36.125" name="Total investment to\nincrease flood\nprotection height"/>
				<stock color="blue" label_side="center" x="866.063" y="543.041" width="103.095" height="57.8571" name="Average flood\nprotection height"/>
				<flow color="blue" label_side="top" x="742.317" y="559.756" width="24.4286" height="24.4286" name="Increase of average\nflood protection height\nthrough investment">
					<pts>
						<pt x="631" y="571.97"/>
						<pt x="866.063" y="571.97"/>
					</pts>
				</flow>
